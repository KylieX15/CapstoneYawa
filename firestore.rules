rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getRole() == 'admin';
    }

    function isEmployee() {
      return isAuthenticated() && getRole() == 'employee';
    }

    function isRider() {
      return isAuthenticated() && getRole() == 'rider';
    }

    // Admin or employee — can manage orders
    function isStaff() {
      return isAdmin() || isEmployee();
    }

    // ── users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Each user reads their own doc; admins read all.
      allow read: if isOwner(uid) || isAdmin();

      // Self-registration: customers only.
      allow create: if isOwner(uid)
                    && request.resource.data.role == 'customer';

      // Admin creating a staff/rider account.
      allow create: if isAdmin()
                    && (request.resource.data.role == 'employee'
                        || request.resource.data.role == 'rider');

      // Profile updates — role field must not change.
      allow update: if isOwner(uid)
                    && request.resource.data.role == resource.data.role;

      allow delete: if isAdmin();
    }

    // ── menuItems ─────────────────────────────────────────────────────────────
    match /menuItems/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── orders ────────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Customers see their own; staff and riders see all.
      allow read: if isAuthenticated()
                  && (resource.data.customerId == request.auth.uid
                      || isStaff()
                      || isRider());

      // Only customers may place an order for themselves.
      allow create: if isAuthenticated()
                    && request.resource.data.customerId == request.auth.uid
                    && getRole() == 'customer';

      // Staff (admin/employee) can update any order field.
      // Riders can only update status and updatedAt.
      allow update: if isStaff()
                    || (isRider()
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['status', 'updatedAt']));

      allow delete: if false;
    }
  }
}
