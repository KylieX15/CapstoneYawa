rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getRole() == 'admin';
    }

    // ── users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      // A user may read their own document; admins may read all.
      allow read: if isOwner(uid) || isAdmin();

      // Registration: a user may only create their own doc with role 'customer'.
      allow create: if isOwner(uid)
                    && request.resource.data.role == 'customer';

      // Profile updates allowed but role field must not change.
      allow update: if isOwner(uid)
                    && request.resource.data.role == resource.data.role;

      allow delete: if isAdmin();
    }

    // ── menuItems ─────────────────────────────────────────────────────────────
    match /menuItems/{itemId} {
      // Any authenticated user may read the menu.
      allow read: if isAuthenticated();

      // Only admins may create, update, or delete menu items.
      allow write: if isAdmin();
    }

    // ── orders ────────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Customers see only their own orders; admins see all.
      allow read: if isAuthenticated()
                  && (resource.data.customerId == request.auth.uid || isAdmin());

      // Customers may place an order only for themselves.
      allow create: if isAuthenticated()
                    && request.resource.data.customerId == request.auth.uid;

      // Only admins/staff may advance the order status or verify payment.
      allow update: if isAdmin();

      // Orders are never deleted.
      allow delete: if false;
    }
  }
}
